{
    "$schema": "https://json-schema.org/draft/07/schema#",
    "$id": "https://teagantotally.rocks/deepthought/tests/test-manifest.schema.json",
    "title": "DeepThought test manifest",
    "description": "Language-neutral test surface extracted from a validated DeepThought catalog. Downstream generators for Python, TypeScript, Go, Rust, and other ecosystems consume this manifest rather than reparsing YAML directly.",
    "type": "object",
    "additionalProperties": false,
    "properties": {
        "counts": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
                "scenarios": {
                    "type": "integer",
                    "minimum": 0
                },
                "invariants": {
                    "type": "integer",
                    "minimum": 0
                }
            },
            "required": [
                "scenarios",
                "invariants"
            ]
        },
        "scenarios": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": {
                        "type": "string"
                    },
                    "usecase": {
                        "type": "string",
                        "minLength": 1
                    },
                    "tags": {
                        "type": "array",
                        "items": {
                            "type": "string",
                            "minLength": 1
                        }
                    },
                    "source": {
                        "type": "string",
                        "minLength": 1
                    },
                    "given": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        }
                    },
                    "when": {
                        "type": [
                            "object",
                            "null"
                        ]
                    },
                    "then": {
                        "type": "array",
                        "items": {
                            "type": "object"
                        }
                    }
                },
                "required": [
                    "id",
                    "name",
                    "description",
                    "usecase",
                    "tags",
                    "source",
                    "given",
                    "when",
                    "then"
                ]
            }
        },
        "invariants": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "id": {
                        "type": "string",
                        "minLength": 1
                    },
                    "name": {
                        "type": "string",
                        "minLength": 1
                    },
                    "description": {
                        "type": "string"
                    },
                    "model": {
                        "type": "string",
                        "minLength": 1
                    },
                    "source": {
                        "type": "string",
                        "minLength": 1
                    },
                    "assert": {},
                    "enforcement": {},
                    "raises": {
                        "type": [
                            "string",
                            "null"
                        ]
                    }
                },
                "required": [
                    "id",
                    "name",
                    "description",
                    "model",
                    "source",
                    "assert",
                    "enforcement",
                    "raises"
                ]
            }
        }
    },
    "required": [
        "counts",
        "scenarios",
        "invariants"
    ]
}